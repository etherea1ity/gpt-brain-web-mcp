GPT_BRAIN_BACKEND=web-chatgpt
GPT_BRAIN_DEFAULT_TIER=thinking_heavy
GPT_BRAIN_ALLOW_PRO_DEFAULT=false
GPT_BRAIN_BROWSER_HEADLESS=true
GPT_BRAIN_BROWSER_VISIBLE=false
GPT_BRAIN_HOME=$HOME/.gpt-brain-web
GPT_BRAIN_MAX_BROWSER_JOBS=1

# For CI/mock only:
# GPT_BRAIN_WEB_MOCK=1

# Live test is gated and sends one short prompt only:
# RUN_LIVE_CHATGPT_WEB=1
